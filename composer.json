{
    "name": "collinflicktasus/laravel-progress",
    "description": "Custom Laravel database driver for Progress/OpenEdge connections",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Collin Flick",
            "email": "collin.flick@tasus.com"
        }
